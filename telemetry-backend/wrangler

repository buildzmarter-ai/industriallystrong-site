# Cloudflare Worker config for industriallystrong.com telemetry
# Docs: https://developers.cloudflare.com/workers/wrangler/configuration/

name = "is-telemetry"
main = "src/worker.js"
compatibility_date = "2024-12-01"

# Bind the D1 database.  After creating it, paste the real database_id below.
# Create with:  wrangler d1 create is-telemetry
# Apply schema:  wrangler d1 execute is-telemetry --file=./schema.sql

[[d1_databases]]
binding = "DB"
database_name = "is-telemetry"
database_id = "1d7ce7c3-98bc-4bd5-98b4-3d95870ac1dc"

# Route through your main domain
[routes]
pattern = "industriallystrong.com/api/telemetry"
zone_name = "industriallystrong.com"
